# Real payment test — copy to .env and fill in your NOWPayments API key

# Get key from: https://account.nowpayments.io → Settings → API
NOWPAYMENTS_API_KEY=your-nowpayments-api-key

# Use sandbox first (test without real money): true
# Use live (real crypto): false or remove this line
NOWPAYMENTS_SANDBOX=true

SITE_URL=http://localhost:5173
CRYPTO_PRICE_USD=9

# Required for activation after payment
# Paste contents of scripts/keys/private.pem (run npm run license:keys first)
LICENSE_PRIVATE_KEY=
ACTIVATION_SECRET=change-this-to-a-random-32-char-string

# Optional — sends activation email (otherwise link prints in API terminal)
# RESEND_API_KEY=
# EMAIL_FROM=LocalDrop <hello@yourdomain.com>
